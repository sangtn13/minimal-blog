<div class="author">
    <h1 class="author__heading">Search Results</h1>
</div>

<section class="articles">
    <h2 class="articles__heading">Search Results for "<%= searchTerm %>"</h2>

    <% if (data.length === 0) { %>
        <p>No results found.</p>
    <% } else { %>
        <ul class="article-ul">
            <% data.forEach(post => { %>
                <li>
                    <a href="/post/<%= post._id %>">
                        <span><%= post.title %></span>
                        <span class="article-list__date"><%= post.createdAt.toDateString() %></span>
                    </a>
                </li>
            <% }) %>
        </ul>
    <% } %>