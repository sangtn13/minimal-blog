<a href="/dashboard">&larr; Back to Dashboard </a>
<div class="admin-title">
  <h2>View / Edit Post</h2>
  <form action="/delete-post/<%= data._id %>?_method=DELETE" method="POST">
    <input type="submit" value="Delete" class="btn-delete btn" />
  </form>
</div>

<form action="/edit-post/<%= data._id %>?_method=PUT" method="POST">
  <label for="title">Title:</label>
  <input type="text" value="<%= data.title %>" name="title" required />
  <label for="body">Body:</label>
  <textarea
    name="body"
    cols="50"
    rows="10"
    placeholder="Enter post content"
    required
  >
<%= data.body %>   </textarea
  >
  <button type="submit" value="Edit Post" class="btn">Edit Post</button>
</form>
